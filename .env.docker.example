###############################################################################
# Userbot Manager — Production .env for docker-compose
#
# Workflow:
#   cp .env.docker.example .env
#   # Generate secrets:
#   docker run --rm python:3.13-slim python -c "import secrets; print(secrets.token_urlsafe(50))"   → SECRET_KEY
#   docker run --rm python:3.13-slim sh -c "pip install -q cryptography && python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'"   → DB_ENCRYPTION_KEY
#   docker run --rm python:3.13-slim python -c "import secrets; print(secrets.token_urlsafe(32))"   → POSTGRES_PASSWORD
#
# Then point an A record for SITE_DOMAIN at this server's IP and:
#   docker compose up -d
#
# After the stack is healthy, install the host nginx config so the public
# domain reaches the web container — see ./nginx/userbots.omadli.uz.conf.
###############################################################################

# ─────────────────────────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────────────────────────

# Public domain — used by host nginx + certbot.
SITE_DOMAIN=userbots.omadli.uz

# Comma-separated; must include SITE_DOMAIN. Add other hostnames if needed.
ALLOWED_HOSTS=userbots.omadli.uz

# Localhost-only port the web container listens on. Host nginx proxies to it.
# Change ONLY if another docker project on this server already uses 8000.
WEB_BIND_PORT=8000


# ─────────────────────────────────────────────────────────────────────────────
# Telegram credentials  (https://my.telegram.org/auth)
# ─────────────────────────────────────────────────────────────────────────────
API_ID=
API_HASH=


# ─────────────────────────────────────────────────────────────────────────────
# Django security
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED in production — generate fresh, do not reuse from a tutorial.
SECRET_KEY=''

# Production = False. Forcing True here exposes admin URLs and disables HSTS.
DEBUG=False

# Host nginx terminates TLS and sets X-Forwarded-Proto. With this True,
# Django emits absolute URLs as https:// and enables SECURE_SSL_REDIRECT.
SECURE_BEHIND_PROXY=True


# ─────────────────────────────────────────────────────────────────────────────
# DB-at-rest encryption — REQUIRED in production
# ─────────────────────────────────────────────────────────────────────────────

# Fernet key. Losing this destroys every stored Telethon session — back it up
# (e.g., in a password manager) before first deploy.
DB_ENCRYPTION_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────

DB_ENGINE=postgres
POSTGRES_DB=userbots
POSTGRES_USER=userbots
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432


# ─────────────────────────────────────────────────────────────────────────────
# Tuning
# ─────────────────────────────────────────────────────────────────────────────

# Uvicorn workers per `web` container. 2 is fine for ≤200 accounts; raise to
# 4 if the dashboard feels slow.
WEB_WORKERS=2

# Root logger level for ./logs/app.log. INFO is a good default; DEBUG floods
# the file with SQL / Telethon traffic.
LOG_LEVEL=INFO


# ─────────────────────────────────────────────────────────────────────────────
# Backup → Telegram (optional, but strongly recommended)
#
# When both vars are set, `make backup` (and the daily cron) uploads the
# db.sql.gz + media.tar.gz + .env.backup files to a Telegram chat right
# after writing them to ./backups/<ts>/.  Telegram itself stores them
# offsite indefinitely — losing the VPS means losing the local copy
# only, the cloud copy survives.
#
# Setup:
#   1. Create a bot via @BotFather  → copy the token into BACKUP_BOT_TOKEN.
#   2. Create a private channel or use Saved Messages, add the bot as admin.
#   3. Forward any message from that chat to @userinfobot to get the numeric
#      chat ID (channels look like `-100123456789`).  Put it in BACKUP_CHAT_ID.
#   4. Bot upload limit via Telethon is ~2 GB per file; gzipped DB dumps for
#      this app are typically <100 MB so we're nowhere near the cap.
#
# Leave both blank to disable — backup still runs, just no Telegram step.
# ─────────────────────────────────────────────────────────────────────────────
BACKUP_BOT_TOKEN=
BACKUP_CHAT_ID=
