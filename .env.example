###############################################################################
# Userbot Manager — Local development .env
#
# 1. cp .env.example .env
# 2. Generate secrets (see commands below)
# 3. Fill in API_ID / API_HASH from https://my.telegram.org/auth
###############################################################################

# ─────────────────────────────────────────────────────────────────────────────
# Telegram MTProto credentials
# Required. Each Telethon client uses these unless an Account row overrides.
# Get them at: https://my.telegram.org/auth → API development tools
# ─────────────────────────────────────────────────────────────────────────────
API_ID=
API_HASH=


# ─────────────────────────────────────────────────────────────────────────────
# Django security
# ─────────────────────────────────────────────────────────────────────────────

# Generate:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Wrap in single quotes — Python-dotenv does $-interpolation otherwise.
SECRET_KEY=''

# True for local development. NEVER true in production.
DEBUG=True

# Comma-separated. Add your domain(s) in production.
ALLOWED_HOSTS=localhost,127.0.0.1

# Set True only when running behind an HTTPS reverse proxy (Caddy/nginx) that
# sets the X-Forwarded-Proto header. Required for SECURE_SSL_REDIRECT.
SECURE_BEHIND_PROXY=False


# ─────────────────────────────────────────────────────────────────────────────
# Field-level encryption (Account.session_string, Account.two_fa_password)
# ─────────────────────────────────────────────────────────────────────────────

# Generate:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Losing this key = all stored sessions become unreadable. Back it up.
# Leave empty to derive from SECRET_KEY (PBKDF2). Setting it explicitly lets
# you rotate SECRET_KEY without breaking decryption.
DB_ENCRYPTION_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────

# 'sqlite' (default — fine for local) or 'postgres' (recommended in production)
DB_ENGINE=sqlite

# Postgres settings (ignored when DB_ENGINE=sqlite)
POSTGRES_DB=userbots
POSTGRES_USER=userbots
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432
