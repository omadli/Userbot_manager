# Caddy v2 reverse proxy for userbots.omadli.uz
#
# `${SITE_DOMAIN}` comes from .env via docker-compose env_file → Caddy.
# Caddy auto-issues a Let's Encrypt certificate on first request.
# Port 80 must be open on the host for the HTTP-01 challenge.

{$SITE_DOMAIN:userbots.omadli.uz} {
    encode zstd gzip

    # Serve collected static files directly — no need to go through Django.
    # The `staticfiles` volume is mounted read-only at /srv/static.
    handle_path /static/* {
        root * /srv/static
        file_server {
            precompressed gzip br
        }
        # Hashed filenames (ManifestStaticFilesStorage) → safe to cache forever.
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # User-uploaded avatars and other media.
    handle_path /media/* {
        root * /srv/media
        file_server
        header Cache-Control "public, max-age=86400"
    }

    # Everything else → Django ASGI on the internal network.
    reverse_proxy web:8000 {
        # Pass real client IP and proto so Django can build correct URLs and
        # so SECURE_PROXY_SSL_HEADER works.
        header_up X-Forwarded-For   {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up Host              {host}

        # Active upstream probe — if Django /healthz starts failing, Caddy
        # serves 502 immediately instead of waiting per-request to time out.
        health_uri /healthz
        health_interval 30s
        health_timeout 5s
    }

    # Some baseline security headers. CSP is intentionally lax because the
    # admin uses inline scripts; tighten if you remove the Django admin.
    header {
        # Prevent click-jacking on top of Django's X_FRAME_OPTIONS.
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "same-origin"
        # Tell browsers to upgrade any HTTP subrequests to HTTPS.
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Caddy adds its own server header; remove for less fingerprinting.
        -Server
    }

    log {
        output stdout
        format console
    }
}
